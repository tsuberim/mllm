FROM python:3.12-slim

# CLI tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget bash \
    ripgrep fd-find tree \
    diffutils patch \
    zip unzip tar \
    make \
    sqlite3 \
    jq \
    libxml2-utils \
    && rm -rf /var/lib/apt/lists/*

# yq (GitHub release — not in apt)
RUN curl -sSL https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 \
    -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq

# csvkit
RUN pip install --no-cache-dir csvkit

# fd is installed as fdfind on debian — alias it
RUN ln -s /usr/bin/fdfind /usr/local/bin/fd

# Python packages
RUN pip install --no-cache-dir \
    numpy pandas scipy matplotlib scikit-learn \
    requests httpx beautifulsoup4 \
    pytest ruff black \
    pyyaml sqlalchemy \
    rich tqdm

WORKDIR /workspace
